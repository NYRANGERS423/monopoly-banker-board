# PORT is 3000 for local dev so the Vite proxy (which hard-codes localhost:3000)
# can reach it. The production / container default is 3030 — see Dockerfile.
PORT=3000
ADMIN_CODE=1413
DEFAULT_CURRENCY=classic
DEFAULT_FREE_PARKING_ENABLED=true
DEFAULT_STARTING_BALANCE=1500
DEFAULT_PASS_GO_AMOUNT=200
DB_PATH=./data/banker.db
NODE_ENV=development
